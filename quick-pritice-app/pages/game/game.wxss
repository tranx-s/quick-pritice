/* pages/game/game.wxss */
.game-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fef3c7 0%, #ffffff 100%);
  padding: 40rpx;
}

.game-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.game-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.game-subtitle {
  display: block;
  font-size: 28rpx;
  color: #64748b;
}

.game-modes {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.mode-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.mode-card.tower {
  background: linear-gradient(135deg, #a78bfa 0%, #ec4899 100%);
  color: white;
}

.mode-card.speed {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  color: white;
}

.mode-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.mode-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.mode-desc {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 24rpx;
}

.mode-stats {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  opacity: 0.95;
}

.rank-entry {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.rank-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.rank-text {
  font-size: 30rpx;
  color: #334155;
  font-weight: 500;
}
