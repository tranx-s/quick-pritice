<!--pages/profile/profile.wxml-->
<view class="profile-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <image class="avatar" src="{{userInfo.avatar || '/assets/default-avatar.png'}}" />
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '点击登录'}}</text>
      <view class="vip-badge" wx:if="{{userInfo.vipStatus}}">
        <text>👑 会员</text>
      </view>
    </view>
    <button class="btn-login" wx:if="{{!userInfo.nickname}}" open-type="getUserInfo" bindgetuserinfo="getUserInfo">
      授权登录
    </button>
  </view>

  <!-- 数据统计 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{userInfo.todayQuestions || 0}}</text>
      <text class="stat-label">今日刷题</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{userInfo.totalQuestions || 0}}</text>
      <text class="stat-label">累计刷题</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{userInfo.currentFloor || 1}}</text>
      <text class="stat-label">闯关层数</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToWrong">
      <text class="menu-icon">📝</text>
      <text class="menu-text">我的错题</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToCollect">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">收藏题目</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToVip">
      <text class="menu-icon">👑</text>
      <text class="menu-text">会员中心</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToFeedback">
      <text class="menu-icon">💬</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
