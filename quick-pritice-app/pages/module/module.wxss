.module-wrap { min-height: 100vh; background: #f8fafc; padding: 30rpx; }
.page-title { font-size: 44rpx; font-weight: 800; color: #1e293b; margin-bottom: 8rpx; }
.page-sub { font-size: 26rpx; color: #94a3b8; margin-bottom: 40rpx; }
.module-list { display: flex; flex-direction: column; gap: 20rpx; }
.module-card { display: flex; align-items: center; justify-content: space-between;
  border-radius: 20rpx; border: 2rpx solid; padding: 30rpx; }
.mc-left { display: flex; align-items: center; gap: 24rpx; }
.mc-icon { font-size: 56rpx; }
.mc-name { font-size: 34rpx; font-weight: 700; }
.mc-count { font-size: 24rpx; color: #94a3b8; margin-top: 6rpx; }
.mc-arrow { font-size: 48rpx; font-weight: 300; }

/* 答题区 */
.answer-bar { display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0; margin-bottom: 12rpx; }
.ab-left { font-size: 28rpx; font-weight: 700; color: #1e293b; }
.ab-progress { font-size: 30rpx; font-weight: 700; color: #3b82f6; }
.ab-answered { font-size: 24rpx; color: #94a3b8; }
.prog-wrap { height: 8rpx; background: #e2e8f0; border-radius: 4rpx; margin-bottom: 24rpx; }
.prog-fill { height: 100%; border-radius: 4rpx; transition: width 0.3s; }
.q-card-m { background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.q-num-m { font-size: 24rpx; color: #3b82f6; margin-bottom: 14rpx; }
.q-content-m { font-size: 30rpx; color: #1e293b; line-height: 1.7; }
.opts-m { display: flex; flex-direction: column; gap: 16rpx; }
.opt-m { display: flex; align-items: flex-start; background: #fff; border-radius: 16rpx;
  padding: 22rpx; border: 2rpx solid #e2e8f0;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04); }
.opt-m.opt-selected { border-color: #3b82f6; background: #eff6ff; }
.opt-m.opt-correct { border-color: #10b981; background: #ecfdf5; }
.opt-m.opt-wrong { border-color: #ef4444; background: #fef2f2; }
.oml { width: 44rpx; height: 44rpx; border-radius: 50%; background: #f1f5f9; color: #64748b;
  text-align: center; line-height: 44rpx; font-size: 26rpx; font-weight: 700; flex-shrink: 0; margin-right: 18rpx; }
.omt { font-size: 28rpx; color: #334155; line-height: 1.6; flex: 1; }
.analysis-m { background: #f0fdf4; border-radius: 16rpx; padding: 24rpx; margin-top: 16rpx;
  border-left: 6rpx solid #10b981; }
.al-label { font-size: 28rpx; font-weight: 700; margin-bottom: 12rpx; }
.al-correct { color: #10b981; }
.al-wrong { color: #ef4444; }
.al-content { font-size: 26rpx; color: #475569; line-height: 1.7; }
.btns-m { display: flex; gap: 16rpx; margin-top: 30rpx; }
.bm-nav { flex: 1; background: #f1f5f9; color: #64748b; border-radius: 50rpx; border: none;
  font-size: 28rpx; height: 80rpx; line-height: 80rpx; }
.bm-ana { flex: 1; background: #fff; color: #3b82f6; border-radius: 50rpx;
  border: 2rpx solid #3b82f6; font-size: 28rpx; height: 80rpx; line-height: 80rpx; }
.bm-submit { flex: 1.5; background: linear-gradient(135deg,#3b82f6,#2563eb); color: #fff;
  border-radius: 50rpx; border: none; font-size: 28rpx; font-weight: 700; height: 80rpx; line-height: 80rpx; }

/* 结果页 */
.result-m { text-align: center; padding: 60rpx 20rpx; }
.rm-icon { font-size: 100rpx; }
.rm-module { font-size: 32rpx; color: #64748b; margin: 16rpx 0 10rpx; }
.rm-acc { font-size: 100rpx; font-weight: 900; color: #3b82f6; line-height: 1; }
.rm-acc-label { font-size: 28rpx; color: #94a3b8; margin-bottom: 40rpx; }
.rm-stats { display: flex; justify-content: space-around; background: #fff;
  border-radius: 20rpx; padding: 30rpx; margin-bottom: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.rms-item { text-align: center; }
.rms-val { display: block; font-size: 48rpx; font-weight: 800; }
.rms-val.green { color: #10b981; }
.rms-val.red { color: #ef4444; }
.rms-val.gray { color: #94a3b8; }
.rms-label { display: block; font-size: 24rpx; color: #94a3b8; margin-top: 6rpx; }
.btn-again { background: linear-gradient(135deg,#3b82f6,#2563eb); color: #fff;
  border-radius: 50rpx; border: none; font-size: 32rpx; font-weight: 700;
  height: 90rpx; line-height: 90rpx; margin-bottom: 20rpx; }
.btn-back-plain { background: transparent; color: #94a3b8; border: none; font-size: 28rpx; }
