.wrong-wrap { min-height: 100vh; background: #f8fafc; padding: 30rpx; }
.wrong-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 30rpx; }
.wh-title { font-size: 44rpx; font-weight: 800; color: #1e293b; }
.wh-count { font-size: 26rpx; color: #94a3b8; }
.empty-wrap { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 100rpx; }
.empty-text { font-size: 30rpx; color: #94a3b8; margin-top: 20rpx; }
.empty-tip { text-align: center; color: #94a3b8; padding: 60rpx; font-size: 28rpx; }

.wrong-list { display: flex; flex-direction: column; gap: 16rpx; }
.wrong-item { background: #fff; border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.wi-row { display: flex; align-items: flex-start; justify-content: space-between; padding: 24rpx; }
.wi-left { flex: 1; margin-right: 16rpx; }
.wi-module-tag { display: inline-block; background: #fee2e2; color: #ef4444;
  border-radius: 8rpx; padding: 4rpx 14rpx; font-size: 22rpx; font-weight: 600; margin-bottom: 12rpx; }
.wi-content { font-size: 28rpx; color: #334155; line-height: 1.6;
  display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.wi-right { flex-shrink: 0; text-align: center; }
.wi-wrong-count { font-size: 22rpx; color: #ef4444; font-weight: 700; margin-bottom: 8rpx; }
.wi-arrow { font-size: 22rpx; color: #94a3b8; }

/* 展开详情 */
.wi-detail { padding: 0 24rpx 24rpx; border-top: 1rpx solid #f1f5f9; }
.wd-opts { display: flex; flex-direction: column; gap: 12rpx; margin-top: 16rpx; }
.wd-opt { display: flex; align-items: flex-start; }
.wd-opt.correct .wdo-label { background: #10b981; color: #fff; }
.wdo-label { width: 40rpx; height: 40rpx; border-radius: 50%; background: #f1f5f9; color: #64748b;
  text-align: center; line-height: 40rpx; font-size: 24rpx; font-weight: 700;
  flex-shrink: 0; margin-right: 14rpx; }
.wdo-label.correct { background: #10b981; color: #fff; }
.wdo-text { font-size: 26rpx; color: #475569; line-height: 1.6; flex: 1; }
.wd-answer { font-size: 26rpx; color: #475569; margin-top: 16rpx; }
.wd-ans-letter { color: #10b981; font-weight: 800; font-size: 30rpx; }
.wd-analysis { background: #f0fdf4; border-radius: 12rpx; padding: 20rpx; margin-top: 14rpx; }
.wd-ana-label { font-size: 24rpx; color: #10b981; font-weight: 700; margin-bottom: 8rpx; }
.wd-ana-text { font-size: 26rpx; color: #475569; line-height: 1.7; }
.wd-actions { display: flex; justify-content: flex-end; margin-top: 16rpx; }
.wda-del { font-size: 24rpx; color: #ef4444; padding: 10rpx 20rpx;
  background: #fef2f2; border-radius: 12rpx; }
