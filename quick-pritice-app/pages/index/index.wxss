/* pages/index/index.wxss */
.index-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #ffffff 100%);
  padding: 40rpx;
}

/* 标语区域 */
.slogan {
  text-align: center;
  margin: 60rpx 0;
}

.slogan-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.slogan-subtitle {
  display: block;
  font-size: 28rpx;
  color: #64748b;
}

/* 主按钮区域 */
.main-buttons {
  margin: 60rpx 0;
}

.btn-card {
  background: white;
  border-radius: 24rpx;
  padding: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s;
}

.btn-card:active {
  transform: scale(0.98);
}

.btn-practice {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-game {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.btn-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.btn-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.btn-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 快捷入口 */
.shortcuts {
  display: flex;
  gap: 24rpx;
  margin: 40rpx 0;
}

.shortcut-item {
  flex: 1;
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.shortcut-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.shortcut-text {
  font-size: 28rpx;
  color: #334155;
}

/* 数据统计 */
.stats {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 60rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e2e8f0;
}
