<view class="wrong-wrap">
  <view class="wrong-header">
    <view class="wh-title">错题本</view>
    <view class="wh-count">共 {{wrongList.length}} 题</view>
  </view>

  <block wx:if="{{loading}}">
    <view class="empty-tip">加载中...</view>
  </block>

  <block wx:elif="{{wrongList.length === 0}}">
    <view class="empty-wrap">
      <view class="empty-icon">📝</view>
      <view class="empty-text">暂无错题，继续加油！</view>
    </view>
  </block>

  <block wx:else>
    <view class="wrong-list">
      <view wx:for="{{wrongList}}" wx:key="wrongId" class="wrong-item">
        <!-- 题目摘要行 -->
        <view class="wi-row" bindtap="toggleExpand" data-wrongid="{{item.wrongId}}">
          <view class="wi-left">
            <view class="wi-module-tag">{{item.question.moduleType}}</view>
            <view class="wi-content">{{item.question.content}}</view>
          </view>
          <view class="wi-right">
            <view class="wi-wrong-count">错{{item.wrongCount}}次</view>
            <view class="wi-arrow">{{expandedId === item.wrongId ? '▲' : '▼'}}</view>
          </view>
        </view>

        <!-- 展开详情 -->
        <view wx:if="{{expandedId === item.wrongId}}" class="wi-detail">
          <view class="wd-opts">
            <view class="wd-opt" wx:for="{{['A','B','C','D']}}" wx:key="*this"
              class="wd-opt {{item === item.question.correctAnswer ? 'correct' : ''}}">
              <text class="wdo-label {{item === item.question.correctAnswer ? 'correct' : ''}}">{{item}}</text>
              <text class="wdo-text">
                {{item === 'A' ? item.question.optionA :
                  item === 'B' ? item.question.optionB :
                  item === 'C' ? item.question.optionC :
                  item.question.optionD}}
              </text>
            </view>
          </view>
          <view class="wd-answer">正确答案：<text class="wd-ans-letter">{{item.question.correctAnswer}}</text></view>
          <view wx:if="{{item.question.analysis}}" class="wd-analysis">
            <view class="wd-ana-label">解析</view>
            <view class="wd-ana-text">{{item.question.analysis}}</view>
          </view>
          <view class="wd-actions">
            <view class="wda-del" bindtap="deleteWrong" data-questionid="{{item.question.id}}">
              🗑 移出错题本
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
