/* pages/practice/practice.wxss */
.practice-container {
  min-height: 100vh;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
}

/* 顶部区域 */
.header {
  background: white;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #e2e8f0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  transition: width 0.3s;
}

.question-count {
  font-size: 28rpx;
  color: #64748b;
  text-align: center;
}

.timer {
  text-align: center;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #f59e0b;
}

/* 题目内容 */
.question-content {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.question-text {
  font-size: 32rpx;
  line-height: 1.8;
  color: #1e293b;
  margin-bottom: 40rpx;
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
}

/* 选项 */
.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  background: white;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  transition: all 0.3s;
}

.option-item.selected {
  border-color: #667eea;
  background: #f0f4ff;
}

.option-label {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e2e8f0;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.option-item.selected .option-label {
  background: #667eea;
  color: white;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: #334155;
}

/* 答案解析 */
.analysis {
  margin-top: 32rpx;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
}

.analysis-header {
  margin-bottom: 16rpx;
}

.analysis-result {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.analysis-result.correct {
  color: #10b981;
}

.analysis-result.wrong {
  color: #ef4444;
}

.correct-answer {
  display: block;
  font-size: 28rpx;
  color: #667eea;
}

.analysis-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #64748b;
  padding-top: 16rpx;
  border-top: 2rpx solid #f1f5f9;
}

/* 底部按钮 */
.footer {
  background: white;
  padding: 24rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.btn-group {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-secondary {
  background: #f1f5f9;
  color: #64748b;
}

.btn[disabled] {
  opacity: 0.5;
}
