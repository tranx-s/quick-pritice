.tower-wrap { min-height: 100vh; background: #1a1a2e; padding: 20rpx; }

/* 准备页 */
.ready-header { text-align: center; padding: 60rpx 0 20rpx; }
.floor-badge { font-size: 56rpx; font-weight: 800; color: #e94560; }
.max-floor { font-size: 26rpx; color: #888; margin-top: 10rpx; }
.life-row { display: flex; align-items: center; justify-content: center; gap: 8rpx; margin: 30rpx 0; }
.life-icon { font-size: 40rpx; }
.life-icon.alive { color: #e94560; }
.life-icon.dead { color: #333; }
.life-label { font-size: 26rpx; color: #aaa; margin-left: 12rpx; }
.rule-card { background: #16213e; border-radius: 20rpx; padding: 30rpx; margin: 30rpx 0; }
.rule-title { color: #e94560; font-size: 30rpx; font-weight: 700; margin-bottom: 20rpx; }
.rule-item { color: #ccc; font-size: 28rpx; line-height: 2; }
.btn-start { background: linear-gradient(135deg, #e94560, #c62a47); color: #fff; border-radius: 50rpx;
  font-size: 34rpx; font-weight: 700; height: 90rpx; line-height: 90rpx; border: none; margin-top: 20rpx; }
.btn-start.disabled { background: #333; color: #666; }

/* 答题页 */
.answer-header { display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 10rpx; margin-bottom: 10rpx; }
.header-left, .header-right { font-size: 26rpx; color: #ccc; }
.header-progress { font-size: 30rpx; font-weight: 700; color: #e94560; }
.life-dot { font-size: 24rpx; }
.life-dot.alive { color: #e94560; }
.life-dot.dead { color: #333; }
.prog-bar-bg { height: 6rpx; background: #2a2a4a; border-radius: 3rpx; margin-bottom: 20rpx; }
.prog-bar-fill { height: 100%; background: #e94560; border-radius: 3rpx; transition: width 0.3s; }
.question-card { background: #16213e; border-radius: 20rpx; padding: 30rpx; margin-bottom: 20rpx; }
.q-num { font-size: 24rpx; color: #e94560; margin-bottom: 14rpx; }
.q-content { font-size: 30rpx; color: #eee; line-height: 1.7; }
.options { display: flex; flex-direction: column; gap: 16rpx; }
.option-item { display: flex; align-items: flex-start; background: #16213e; border-radius: 16rpx;
  padding: 24rpx; border: 2rpx solid transparent; }
.option-item.selected { border-color: #e94560; background: #2a1525; }
.option-item.correct { border-color: #4ade80; background: #0f2a1a; }
.option-item.wrong { border-color: #f87171; background: #2a0f0f; }
.opt-label { width: 44rpx; height: 44rpx; border-radius: 50%; background: #2a2a4a; color: #aaa;
  text-align: center; line-height: 44rpx; font-size: 26rpx; font-weight: 700; flex-shrink: 0; margin-right: 18rpx; }
.opt-text { font-size: 28rpx; color: #ddd; line-height: 1.6; flex: 1; }
.analysis-box { background: #0d2137; border-radius: 16rpx; padding: 24rpx; margin-top: 20rpx; }
.analysis-label { font-size: 28rpx; font-weight: 700; margin-bottom: 14rpx; }
.correct-text { color: #4ade80; }
.wrong-text { color: #f87171; }
.analysis-content { font-size: 26rpx; color: #bbb; line-height: 1.7; }
.btn-row { display: flex; gap: 16rpx; margin-top: 30rpx; }
.btn-nav { flex: 1; background: #2a2a4a; color: #ccc; border-radius: 50rpx; border: none; font-size: 28rpx; height: 80rpx; line-height: 80rpx; }
.btn-analysis { flex: 1; background: #16213e; color: #e94560; border-radius: 50rpx; border: 2rpx solid #e94560; font-size: 28rpx; height: 80rpx; line-height: 80rpx; }
.btn-submit-floor { flex: 1.5; background: linear-gradient(135deg, #e94560, #c62a47); color: #fff;
  border-radius: 50rpx; border: none; font-size: 28rpx; font-weight: 700; height: 80rpx; line-height: 80rpx; }

/* 结算页 */
.result-wrap { text-align: center; padding: 60rpx 20rpx; }
.result-icon { font-size: 100rpx; }
.result-title { font-size: 50rpx; font-weight: 800; color: #fff; margin: 20rpx 0 10rpx; }
.result-msg { font-size: 28rpx; color: #aaa; margin-bottom: 40rpx; }
.result-stats { display: flex; justify-content: space-around; background: #16213e;
  border-radius: 20rpx; padding: 30rpx; margin-bottom: 40rpx; }
.rs-item { text-align: center; }
.rs-val { display: block; font-size: 44rpx; font-weight: 800; color: #e94560; }
.rs-val.rs-life { color: #4ade80; }
.rs-label { font-size: 24rpx; color: #888; margin-top: 8rpx; display: block; }
.result-btns { display: flex; flex-direction: column; gap: 20rpx; }
.btn-continue { background: linear-gradient(135deg, #e94560, #c62a47); color: #fff;
  border-radius: 50rpx; border: none; font-size: 32rpx; font-weight: 700; height: 90rpx; line-height: 90rpx; }
.btn-continue.disabled { background: #333; color: #666; }
.btn-back-game { background: #16213e; color: #aaa; border-radius: 50rpx; border: none;
  font-size: 28rpx; height: 80rpx; line-height: 80rpx; }
